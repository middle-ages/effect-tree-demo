{
  "display": "browser.stories",
  "extends": ["./tsconfig.browser.json"],
  "compilerOptions": {
    "noEmit": true,
  },
  "include": [
    "../.storybook/preview.tsx",
    "../.storybook/vitest.setup.ts",
    "../src/storybook.ts",
    "../**/*.stories.ts",
